<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
</head>
<body class="bg-[#0f0f0f] text-white">
    <nav class="p-4 border-b border-gray-800 flex items-center gap-4">
        <a href="/" class="text-xl font-bold">仙人Tube</a>
        <form action="/search" class="flex-1 max-w-xl flex bg-[#121212] border border-gray-700 rounded-full px-4 py-1">
            <input type="text" name="q" value="<%= query %>" class="bg-transparent w-full outline-none">
            <button><span class="material-symbols-outlined mt-1">search</span></button>
        </form>
    </nav>
    <main class="max-w-7xl mx-auto p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% videos.forEach(v => { %>
            <% if (v.type === 'channel') { %>
                <!-- チャンネルカード -->
                <a href="/channel/<%= v.id %>" class="flex flex-col items-center gap-4 p-4 bg-[#1a1a1a] rounded-xl hover:bg-[#2a2a2a] transition-all group">
                    <div class="relative w-32 h-32 flex-shrink-0">
                        <img src="<%= v.author.thumbnail %>" class="w-full h-full object-cover rounded-full shadow-lg">
                    </div>
                    <div class="text-center">
                        <h3 class="text-lg font-bold line-clamp-1"><%= v.title %></h3>
                        <p class="text-sm text-gray-400 mt-1">チャンネル</p>
                        <button class="mt-3 bg-white text-black px-4 py-1 rounded-full text-sm font-bold">表示</button>
                    </div>
                </a>
            <% } else { %>
                <!-- 動画カード -->
                <a href="/watch?v=<%= v.id %>" class="flex flex-col gap-3 group">
                    <div class="relative w-full aspect-video">
                        <img src="<%= v.thumbnails[0].url %>" class="w-full h-full object-cover rounded-xl group-hover:rounded-none transition-all duration-300">
                    </div>
                    <div class="flex gap-3 px-1">
                        <img src="<%= v.author.thumbnail %>" class="w-9 h-9 rounded-full flex-shrink-0 bg-gray-700">
                        <div class="flex flex-col">
                            <h3 class="text-sm font-bold line-clamp-2 leading-snug"><%= v.title %></h3>
                            <div class="flex flex-col mt-1">
                                <p class="text-xs text-gray-400 hover:text-white transition"><%= v.author.name %></p>
                            </div>
                        </div>
                    </div>
                </a>
            <% } %>
        <% }) %>
    </main>
</body>
</html>
